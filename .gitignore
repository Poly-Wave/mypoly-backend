# 서비스별 환경변수 파일
user-service/.env
bill-service/.env
bill-batch/.env

# Environment
.env

# Python
__pycache__/
*.py[cod]
env/
venv/

# Node
node_modules/
dist/

# Editor
.vscode/
.idea/

# OS
Thumbs.db
*.log

# Java/Gradle
/.gradle
/build
/out
*.class
*.log
*.war
*.jar
/.mvn
.settings/
target/

# === 실무 빌드/산출물 완전 차단 ===
build/
bin/
tmp/
distributions/
*.tar
*.zip

user-service/build/
user-service/bin/
user-service/tmp/
user-service/distributions/
user-service/*.tar
user-service/*.zip

bill-service/build/
bill-service/bin/
bill-service/tmp/
bill-service/distributions/
bill-service/*.tar
bill-service/*.zip

# Kubernetes Secret (보안상 git에 포함 금지)
k8s/**/*secret.yaml

# Gradle Wrapper는 커밋 허용 (재현성 필수)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# user-service 금칙어 리스트/랜덤 닉네임 생성 규칙 (로컬에서만 주입)
user-service/src/main/resources/db/migration/V3__seed_nickname_forbidden_words.sql
user-service/src/main/resources/db/migration/V4__seed_nickname_random_words.sql
user-service/src/main/resources/db/migration/V5__seed_administrative_area.sql
