# 루트 .env.example (docker-compose, DB 등 공통 인프라 환경변수)
# 실제 값은 운영 담당자에게 별도 전달/관리하세요.

# PostgreSQL (docker-compose, DB 컨테이너용)
POSTGRES_DB=mypoly
POSTGRES_USER=mypoly
POSTGRES_PASSWORD=실제_DB_비밀번호_여기에_입력
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Spring Boot 공통 환경
SPRING_PROFILES_ACTIVE=local

# JWT (API 인증/인가용)
JWT_SECRET=실제_JWT_시크릿정보_여기에_입력

# (참고) 카카오 OAuth2 등 서비스별 민감정보는 user-service/.env에서 별도 관리
