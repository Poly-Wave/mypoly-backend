apiVersion: v1
kind: Secret
metadata:
  name: user-service-secret
  namespace: mypoly
type: Opaque
stringData:
  # --- REQUIRED by application.properties ---
  # DB
  DB_URL: "jdbc:postgresql://mypoly-postgres:5432/mypoly"
  DB_NAME: "mypoly"
  DB_USERNAME: "mypoly"
  DB_PASSWORD: 실제_비밀번호_여기에_입력

  # Kakao OAuth2
  KAKAO_CLIENT_ID: 실제_클라이언트_ID_여기에_입력
  KAKAO_CLIENT_SECRET: 실제_클라이언트_시크릿_여기에_입력

  # JWT (HS256: 32 bytes+ 권장)
  JWT_SECRET: 실제_JWT_시크릿_여기에_입력
