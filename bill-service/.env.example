# bill-service/.env.example
# 실제 값은 bill-service/.env로 복사해서 사용하고, bill-service/.env는 gitignore 처리하세요.

# service port(호스트)
BILL_SERVICE_PORT=8081

# spring profile
SPRING_PROFILES_ACTIVE=local

# jwt (user-service에서 발급한 JWT를 검증해야 하므로 동일 값 사용)
JWT_SECRET=실제_JWT_시크릿_여기에_입력

# reverse proxy / ingress 환경에서 baseUrl 계산 안정화 (로컬에서도 켜도 무해)
SERVER_FORWARD_HEADERS_STRATEGY=framework

# 로컬은 보통 비움, k8s에서는 /bills 권장
BILL_SERVER_SERVLET_CONTEXT_PATH=
