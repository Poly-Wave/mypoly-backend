# .env.example (실제 배포 시 user-service/.env로 복사)

# 카카오 OAuth2 Client ID (카카오 Developers 콘솔에서 확인)
KAKAO_CLIENT_ID=실제_카카오_클라이언트_ID_여기에_입력

# 카카오 OAuth2 Client Secret (카카오 Developers 콘솔에서 확인)
KAKAO_CLIENT_SECRET=실제_카카오_클라이언트_시크릿_여기에_입력

# DB 접속 정보 (명시적으로 모두 지정)
DB_URL=jdbc:postgresql://db:5432/mypoly
DB_USERNAME=mypoly
DB_PASSWORD=실제_DB_비밀번호_여기에_입력
