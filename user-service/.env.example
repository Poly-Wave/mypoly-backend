# user-service/.env.example
# 실제 값은 user-service/.env로 복사해서 사용하고, user-service/.env는 gitignore 처리하세요.

# service port
USER_SERVICE_PORT=8080

# spring profile
SPRING_PROFILES_ACTIVE=local

# kakao oauth
KAKAO_CLIENT_ID=실제_클라이언트_ID_여기에_입력
KAKAO_CLIENT_SECRET=실제_클라이언트_시크릿_여기에_입력

# jwt
JWT_SECRET=실제_JWT_시크릿_여기에_입력

# reverse proxy / ingress 환경에서 baseUrl 계산 안정화 (로컬에서도 켜도 무해)
SERVER_FORWARD_HEADERS_STRATEGY=framework

# 로컬은 보통 비움, k8s에서는 /users로 사용
SERVER_SERVLET_CONTEXT_PATH=
